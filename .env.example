# ---- Foundry / contracts (root-level .env) ----

# Deployer key used by `forge script Deploy.s.sol`
DEPLOYER_PRIVATE_KEY=

# Mezo Matsnet RPC (default works out of the box)
MEZO_TESTNET_RPC=https://rpc.test.mezo.org

# Optional — for contract verification on the Mezo explorer
ETHERSCAN_API_KEY=

# Inputs for `SeedDemo.s.sol` (copy from deployments/matsnet.json after deploy)
BTC_ADDR=
MUSD_ADDR=
MEZO_ADDR=
VAULT_ADDR=
RECIPIENT_A=
