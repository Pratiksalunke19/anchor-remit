{
  "name": "anchor-remit-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Backend API for Anchor Remit (MUSD) — REST endpoints, chain watcher, Twilio SMS, Transak off-ramp.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "sql.js": "^1.12.0",
    "twilio": "^5.3.3",
    "viem": "^2.21.19",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.7.4",
    "@types/node-cron": "^3.0.11",
    "@types/sql.js": "^1.4.11",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.2"
  }
}
