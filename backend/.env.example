# ---- server ----
PORT=3001
CORS_ORIGIN=http://localhost:5173

# ---- chain ----
MEZO_RPC=https://rpc.test.mezo.org
CHAIN_ID=31611

# Deployed contract addresses (filled after `forge script ... Deploy.s.sol`)
REMITTANCE_VAULT=0x518286f49FcC5a912DdAb30c0d2BA6aA4cC62490
INSURANCE_POOL=0xBe1Be331Da23Ad394fA6Bb4dD84d24Aec5F26224
MEZO_VAULT=0x2E5d564e0b8dD82a7b9f3e69b2CED777f90733E8
MUSD_TOKEN=0xD62AA58463fEEd5816729a9ED460bAb0E3a0101D
BTC_TOKEN=0x36c2Dd5FA96597dbef53906903857413f6818DE9

# ---- keeper (used for liquidationGuard cron job) ----
KEEPER_PRIVATE_KEY=

# ---- Twilio (SMS notifications) ----
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# ---- Transak (fiat off-ramp) ----
TRANSAK_API_KEY=
TRANSAK_ENV=STAGING

# ---- database ----
SQLITE_PATH=./data/anchor-remit.db

# ---- wallet-free recipient experience ----
# 32-byte hex (64 chars). AES-256-GCM key for encrypting embedded-wallet privkeys at rest.
# Generate: `openssl rand -hex 32`
WALLET_KMS_KEY=
# HMAC secret for recipient session tokens.
SESSION_SECRET=
# Pepper mixed into OTP hash before SHA-256.
OTP_PEPPER=
# Native BTC drip (in BTC, 18 decimals on Mezo) sent to each new embedded wallet
# so it can pay gas for outbound transfers without the user ever seeing it.
RELAYER_GAS_DRIP_BTC=0.00005
